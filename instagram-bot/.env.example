# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# A random string you choose — must match what you set in Meta's webhook dashboard
VERIFY_TOKEN=your_random_verify_token_here

# Long-lived Page Access Token from Meta Graph API Explorer
# Requires pages_messaging + instagram_manage_messages permissions
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Your Instagram Professional Account's numeric user ID
# Find it via: GET https://graph.facebook.com/v21.0/me?fields=id&access_token=PAGE_ACCESS_TOKEN
IG_USER_ID=your_instagram_user_id_here

# Port the server listens on (Render/Railway provide this automatically)
PORT=3000
